local function updateButtonDisplay()
    if currentMode == "OFF" then
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
        ToggleBtn.TextColor3 = Color3.fromRGB(130, 130, 135)
        ToggleBtn.Text = "AIM MODE : OFF"
    elseif currentMode == "CAMERA" then
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(245, 245, 245)
        ToggleBtn.TextColor3 = Color3.fromRGB(15, 15, 15)
        ToggleBtn.Text = "AIM : CAMERA"
    elseif currentMode == "TARGET" then
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(255, 100, 100)
        ToggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        ToggleBtn.Text = "AIM : NEAREST"
    elseif currentMode == "SELECT" then
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(100, 180, 255)
        ToggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        local name = selectedPlayer and selectedPlayer.DisplayName or "NONE"
        ToggleBtn.Text = "AIM : " .. string.upper(name)
    end
end

local function cycleMode()
    if isBinding then return end
    
    if currentMode == "OFF" then 
        currentMode = "CAMERA"
    elseif currentMode == "CAMERA" then 
        currentMode = "TARGET"
    elseif currentMode == "TARGET" then
        if selectedPlayer and selectedPlayer.Parent == players and selectedPlayer.Character and selectedPlayer.Character:FindFirstChild("HumanoidRootPart") then
            currentMode = "SELECT"
        else
            currentMode = "OFF"
            selectedPlayer = nil
        end
    elseif currentMode == "SELECT" then 
        currentMode = "OFF"
    else 
        currentMode = "OFF" 
    end
    updateButtonDisplay()
end

