-- 💾 セーブ・ロード機能 (PC内ファイル保存)
-- ==========================================
local SETTINGS_FILE = "aim_controller_settings.json"
local CYCLE_KEY = Enum.KeyCode.P -- デフォルト値

-- 設定を保存する関数
local function saveSettings()
    if writefile then
        local data = {
            Keybind = CYCLE_KEY.Name
        }
        local success, json = pcall(function() return httpService:JSONEncode(data) end)
        if success then
            writefile(SETTINGS_FILE, json)
        end
    end
end

-- 設定を読み込む関数
local function loadSettings()
    if readfile and isfile and isfile(SETTINGS_FILE) then
        local success, content = pcall(function() return readfile(SETTINGS_FILE) end)
        if success and content then
            local dataSuccess, data = pcall(function() return httpService:JSONDecode(content) end)
            if dataSuccess and data and data.Keybind then
                local keySuccess, keyCode = pcall(function() return Enum.KeyCode[data.Keybind] end)
                if keySuccess and keyCode then
                    CYCLE_KEY = keyCode
                end
            end
        end
    end
end

-- 最初に設定をロード
loadSettings()

